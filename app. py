import streamlit as st
import sqlite3
from datetime import datetime

# Baza podaci
conn = sqlite3.connect('kubanac.db', check_same_thread=False)
cursor = conn.cursor()
cursor.execute('CREATE TABLE IF NOT EXISTS termini (id INTEGER PRIMARY KEY AUTOINCREMENT, ime TEXT, telefon TEXT, usluga TEXT, datum TEXT, vreme TEXT)')
conn.commit()

st.title("💈 Kod Kubanca")
st.write("Sveska kod Lesa")

# Forma
with st.form("forma"):
    ime = st.text_input("Ime i prezime:")
    tel = st.text_input("Telefon:")
    usluga = st.selectbox("Usluga:", ["Šišanje", "Brada", "Komplet"])
    datum = st.date_input("Datum:", min_value=datetime.today())
    vreme = st.selectbox("Vreme:", ["09:00", "10:00", "11:00", "12:00", "13:00", "14:00", "15:00", "16:00", "17:00", "18:00"])
    if st.form_submit_button("Upiši me"):
        if ime and tel:
            cursor.execute("INSERT INTO termini (ime, telefon, usluga, datum, vreme) VALUES (?, ?, ?, ?, ?)", (ime, tel, usluga, str(datum), vreme))
            conn.commit()
            st.success("Uspešno upisano!")
        else:
            st.error("Unesi ime i telefon!")

st.write("---")
st.subheader("📅 Sveska")
dan = st.date_input("Pogledaj za dan:", datetime.today())
cursor.execute("SELECT ime, usluga, vreme FROM termini WHERE datum = ? ORDER BY vreme ASC", (str(dan),))
for r in cursor.fetchall():
    st.write(f"⏰ **{r[2]}** — {r[0]} ({r[1]})")
